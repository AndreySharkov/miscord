<!DOCTYPE html>
<html lang="en-GB" class="platform-web theme-dark theme-darker images-dark density-default font-size-16 no-webkit-scrollbar mouse-mode full-motion app-focused visual-refresh mana-toggle-inputs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Miscord</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/discord-exact.css" asp-append-version="true" />
</head>
<body>
<div id="app-mount">
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <div class="app-container">

            <!-- 1. Server Sidebar -->
            @await Component.InvokeAsync("ServerSidebar")

            <!-- 2. Channel Sidebar -->
            <aside class="channel-sidebar">

                <header class="sidebar-header">
                    <span class="sidebar-header-name">@(ViewData["ServerName"] ?? "Miscord")</span>
                    <!-- Chevron icon -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:#80848e;flex-shrink:0">
                        <polyline points="6 9 12 15 18 9"/>
                    </svg>
                </header>

                <div class="channel-list">
                    @if (ViewData["Channels"] is IEnumerable<Miscord.Data.Models.Channel> channels)
                    {
                        <!-- Text Channels category -->
                        <div class="channel-category">
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="9 18 15 12 9 6"/>
                            </svg>
                            Text Channels
                        </div>

                        @foreach (var channel in channels)
                        {
                            <a class="channel-item @(channel.Name == (string?)ViewData["ActiveChannel"] ? "active" : "")"
                               href="javascript:void(0)"
                               onclick="loadChannel(@channel.Id)">
                                <!-- Hash icon -->
                                <svg class="ch-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                    <path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                                </svg>
                                <span class="ch-name">@channel.Name</span>
                            </a>
                        }
                    }
                    else
                    {
                        <p class="channel-list-placeholder">Select a server to view channels.</p>
                    }
                </div>

                <!-- User Panel -->
                <div class="user-panel">
                    <div class="user-info">
                        <div class="user-avatar">
                            @User.Identity.Name?.Substring(0, 1).ToUpper()
                            <div class="user-status-dot"></div>
                        </div>
                        <div class="user-details">
                            <div class="user-name">@User.Identity.Name</div>
                            <div class="user-tag">Online</div>
                        </div>
                    </div>

                    <div class="user-panel-actions">
                        <!-- Mute mic -->
                        <button class="up-btn" title="Mute">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                                <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                                <line x1="12" y1="19" x2="12" y2="23"/>
                                <line x1="8" y1="23" x2="16" y2="23"/>
                            </svg>
                        </button>
                        <!-- Deafen headphones -->
                        <button class="up-btn" title="Deafen">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
                                <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
                            </svg>
                        </button>
                        <!-- Settings / Logout -->
                        <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                            <button type="submit" class="up-btn" title="Logout">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="3"/>
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <!-- 3. Main Content -->
            <main class="main-content">
                @RenderBody()
            </main>

        </div>
    }
    else
    {
        <div class="auth-bg">
            @RenderBody()
        </div>
    }
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
